{
	"extends": "@woocommerce/internal-build/configs/tsconfig.json",
	"compilerOptions": {
		"rootDir": "src",
		"outDir": "build-module",
		"declaration": true,
		"declarationMap": true,
		"declarationDir": "./build-types",
		"typeRoots": [
			"./typings",
			"./node_modules/@types"
		],
		"types": [
			"jest"
		],
		"composite": true
	},
	"include": [
		"typings/**/*",
		"src/**/*"
	],
	"exclude": [
		"**/test/**",
		"**/stories/**"
	],
	"references": [
		{
			"path": "../components"
		},
		{
			"path": "../sanitize"
		}
	]
}
