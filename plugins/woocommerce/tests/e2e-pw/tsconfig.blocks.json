{
	"$schema": "https://json.schemastore.org/tsconfig.json",
	"extends": "../../client/blocks/tsconfig.base.json",
	"compilerOptions": {
		"baseUrl": "../../client/blocks",
		"rootDir": "../..",
		"allowJs": true,
		"noEmit": true,
		"composite": false,
		"emitDeclarationOnly": false,
		"checkJs": false
	},
	"include": [
		"tests/blocks/**/*",
		"utils/blocks/**/*",
		"fixtures/blocks-setup.ts",
		"test-data/blocks/**/*"
	]
}
