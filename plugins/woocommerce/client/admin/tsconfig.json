		},
		{
			"path": "../../../../packages/js/explat"
		},
		{
			"path": "../../../../packages/js/navigation"
		},
		{
			"path": "../../../../packages/js/number"
		},
		{
			"path": "../../../../packages/js/onboarding"
		},
		{
			"path": "../../../../packages/js/remote-logging"
