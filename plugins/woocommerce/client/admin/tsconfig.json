{
	"compilerOptions": {
		"noEmit": true,
		"target": "esnext",
		"moduleResolution": "node",
		"allowJs": true,
		"jsx": "preserve",
		"strict": true,
		"esModuleInterop": true,
		"skipLibCheck": true,
		"module": "esnext",
		"baseUrl": "client",
		"paths": {
			"~/*": [
				"*"
			]
		},
		"rootDir": "client",
		"typeRoots": [
			"./client/typings",
			"./node_modules/@types"
		],
		"composite": true
	},
	"include": [
		"./client/**/*"
	],
	"exclude": [
		"**/test/*"
	],
	"references": [
