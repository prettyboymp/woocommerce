	"config": {
		"ci": {
			"lint": {
				"command": "lint",
				"changes": "client/**/*.{js,ts,tsx,scss}"
			},
			"tests": [
				{
					"name": "JavaScript",
					"command": "test:js",
					"changes": [
						"jest.config.js",
						"webpack.config.js",
						"babel.config.js",
						"tsconfig.json",
						"client/**/*.{js,jsx,ts,tsx,scss,json}"
					],
					"events": [
						"pull_request",
						"push"
					]
				}
			]
		}
