{
	"extends": "./tsconfig.base.json",
	"include": [
		"./typings/**/*",
		"./assets/js/**/*",
		"./assets/js/**/*.json",
		"./packages/checkout/**/*",
		"./packages/components/**/*",
		"./assets/js/blocks/**/block.json",
		"./assets/js/atomic/blocks/**/block.json",
		"./assets/js/blocks/mini-cart/mini-cart-contents/inner-blocks/**/block.json",
		"./storybook/**/*",
		"./tests/integration/**/*",
		"./tests/js/**/*",
		"./tests/utils/**/*"
	],
	"exclude": [
		"./storybook/build",
		"./storybook/webpack.config.js",
		"./storybook/preview.js",
		"./bin"
	],
	"compilerOptions": {
		"composite": true
	},
	"references": [
		{
			"path": "../../../../packages/js/email-editor"
		},
		{
			"path": "../../../../packages/js/sanitize"
		},
		{
			"path": "../../../../packages/js/tracks"
		}
	]
}
