{
	"name": "woocommerce/payment-methods",
	"version": "1.0.0",
	"title": "Payment Methods",
	"description": "Display available payment methods.",
	"category": "woocommerce",
	"keywords": ["woocommerce", "payments", "payment methods"],
	"textdomain": "woocommerce",
	"attributes": {
		"className": {
			"type": "string",
			"default": ""
		},
		"showAsIcons": {
			"type": "boolean",
			"default": false
		},
		"formattedPaymentMethods": {
			"type": "object",
			"default": {}
		}
	},
	"supports": {
		"align": ["wide", "full"],
		"html": false,
		"spacing": {
			"margin": true,
			"padding": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		}
	},
	"apiVersion": 3,
	"$schema": "https://schemas.wp.org/trunk/block.json"
}
